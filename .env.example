# .env — Copy this file and fill in your values
# Usage: cp .env.example .env  then edit .env

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get free API key at: https://build.nvidia.com
NVIDIA_API_KEY="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"

# Backend: nim_cloud | nim_local | ollama
LLM_BACKEND=nim_cloud

# NIM Cloud (default) or local NIM endpoint
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use (see main.py --list-models for all options)
MODEL=meta/llama-3.3-70b-instruct

# Enable per-agent model specialization (true/false)
USE_AGENT_MODELS=true

# ── AMD MI300X ────────────────────────────────────────────────────────────────
NUM_PARALLEL=4
CTX_SIZE=8192

# ── Ollama Fallback (if LLM_BACKEND=ollama) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:9b
